NODE_ENV=development
PORT=5000

# Comma-separated origins for CORS (frontend URLs)
CLIENT_URLS=http://localhost:3000,http://localhost:3001

# JWT
JWT_SECRET=change_me_to_a_long_random_secret
JWT_EXPIRE=7d

# Preferred for production-managed databases
DATABASE_URL=

# Fallback DB config when DATABASE_URL is not set
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=
DB_NAME=auto_lens
DB_SSL=false
DB_MAX_POOL_SIZE=10
DB_CONNECTION_TIMEOUT_MS=5000
DB_IDLE_TIMEOUT_MS=30000

# Cloudinary (required for image uploads)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

